# ============================================================
# Android / Gradle
# ============================================================
*.class
*.dex
*.ap_

# Build outputs
build/
**/build/
out/

# Gradle wrapper (keep gradlew scripts, ignore jar & cache)
.gradle/
gradle/wrapper/gradle-wrapper.jar
local.properties

# Keystore / signing
*.jks
*.keystore
release/

# ProGuard
*.map

# Generated source files
gen/
generated/

# AAR / JAR outputs
*.aar
*.jar

